        task.spawn(function()
            while flingActive do
                local char = getChar()
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    local cf = root.CFrame
                    root.CFrame = CFrame.new(1e7, 1e7, 1e7)
