local function findTargetPlayer()
    local targetName = Input.Text
    if not targetName or #targetName < 3 then
        return nil
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Name:lower():find(targetName:lower(), 1, true) then
            return p
        end
    end

    return nil
end

local function restoreMyCamera()
    local camera = workspace.CurrentCamera
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")

    if camera then
        camera.CameraType = OriginalCameraType or Enum.CameraType.Custom
        camera.CameraSubject = hum or OriginalCameraSubject
    end

    OriginalCameraType = nil
    OriginalCameraSubject = nil
end

