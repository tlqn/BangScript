local function doReset()
    if resetCooldown then return end
    resetCooldown = true
    task.spawn(function()
        LocalPlayer:LoadCharacter()
        task.wait(3)
        resetCooldown = false
    end)
end

local function watchCharacter(char)
    if not char then return end
    char.DescendantAdded:Connect(function(obj)
        if resetCooldown then return end
        local name = obj.Name:lower()
        if name:find("handcuff") or name:find("cuff") or name:find("arrest") then
            doReset() return
        end
        if obj:IsA("BallSocketConstraint") or obj:IsA("RopeConstraint")
        or obj:IsA("WeldConstraint") or obj:IsA("HingeConstraint") then
            doReset() return
        end
    end)
    local humanoid = char:WaitForChild("Humanoid", 5)
    if humanoid then
        humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if humanoid.WalkSpeed == 0 and not resetCooldown then
                doReset()
            end
        end)
    end
end

