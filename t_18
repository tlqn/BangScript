local function hdSendChat(msg)
    -- طريقة ١: LocalPlayer:Chat — تشغّل Chatted على السيرفر مباشرة
    -- (الأكثر توافقاً مع الـ executors المختلفة)
    pcall(function()
        game:GetService("Players").LocalPlayer:Chat(msg)
    end)

    -- طريقة ٢: TextChatService (نظام Roblox الجديد)
    pcall(function()
        local tcs = game:GetService("TextChatService")
        if tcs.ChatVersion ~= Enum.ChatVersion.TextChatService then return end
        local ch = tcs.TextChannels:FindFirstChild("RBXGeneral")
                or tcs.TextChannels:GetChildren()[1]
        if ch then
            task.spawn(function() pcall(function() ch:SendAsync(msg) end) end)
        end
    end)

    -- طريقة ٣: SayMessageRequest (نظام Roblox القديم)
    pcall(function()
        game:GetService("ReplicatedStorage")
            .DefaultChatSystemChatEvents
            .SayMessageRequest:FireServer(msg, "All")
    end)
end
