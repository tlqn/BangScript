local function stopTargetFling(restorePosition)
    targetFlingActive = false
    local savedCFrame = targetFlingSavedCFrame

    if targetFlingConnection then
        targetFlingConnection:Disconnect()
        targetFlingConnection = nil
    end

    if targetFlingAngularVelocity then
        targetFlingAngularVelocity:Destroy()
        targetFlingAngularVelocity = nil
    end

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then
        hum.AutoRotate = true
    end

    if root then
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end

    if restorePosition and savedCFrame then
        task.spawn(function()
            for _ = 1, 4 do
                local currentChar = LocalPlayer.Character
                local currentRoot = currentChar and currentChar:FindFirstChild("HumanoidRootPart")
                if not currentRoot then
                    break
                end

                currentRoot.AssemblyLinearVelocity = Vector3.zero
                currentRoot.AssemblyAngularVelocity = Vector3.zero
                currentRoot.CFrame = savedCFrame
                RunService.Heartbeat:Wait()
            end
        end)
    end

    targetFlingSavedCFrame = nil
    targetFlingAngle = 0
    targetFlingPulse = 0
    targetFlingStartTargetY = nil
    targetFlingStartTime = 0
    setButtonState(TargetFlingBtn, false, "إيقاف الفلنق", "فلنق", Theme.Danger, Theme.PanelSoft)
end

local function startTargetFling(target)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    local targetChar = target and target.Character
    local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")

    if not root or not hum or not targetRoot then
        return
    end

    targetFlingActive = true
    targetFlingSavedCFrame = root.CFrame
    targetFlingAngle = 0
    targetFlingPulse = 0
    targetFlingStartTargetY = targetRoot.Position.Y
    targetFlingStartTime = tick()
    hum.AutoRotate = false

    targetFlingAngularVelocity = Instance.new("BodyAngularVelocity")
    targetFlingAngularVelocity.Name = "TargetFlingAngularVelocity"
    targetFlingAngularVelocity.MaxTorque = Vector3.new(0, math.huge, 0)
    targetFlingAngularVelocity.AngularVelocity = Vector3.new(0, 2400, 0)
    targetFlingAngularVelocity.P = 100000
    targetFlingAngularVelocity.Parent = root

    setButtonState(TargetFlingBtn, true, "إيقاف الفلنق", "فلنق", Theme.Danger, Theme.PanelSoft)

    targetFlingConnection = RunService.Heartbeat:Connect(function()
        if not targetFlingActive then
            return
        end

        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local myHum = myChar and myChar:FindFirstChild("Humanoid")
        local currentTargetChar = target.Character
        local currentTargetRoot = currentTargetChar and currentTargetChar:FindFirstChild("HumanoidRootPart")
        local currentTargetHum = currentTargetChar and currentTargetChar:FindFirstChildOfClass("Humanoid")

        if not myRoot or not myHum or myHum.Health <= 0 or not currentTargetRoot or not currentTargetHum or currentTargetHum.Health <= 0 then
            stopTargetFling(true)
            return
        end

        local targetRaisedEnough = targetFlingStartTargetY and currentTargetRoot.Position.Y > (targetFlingStartTargetY + 5)
        local targetGoingUpFast = currentTargetRoot.AssemblyLinearVelocity.Y > 55
        local activeLongEnough = (tick() - targetFlingStartTime) > 0.18

        if activeLongEnough and (targetRaisedEnough or targetGoingUpFast) then
            stopTargetFling(true)
            return
        end

        targetFlingAngle += math.rad(160)
        targetFlingPulse = (targetFlingPulse % 3) + 1

        local contactOffsets = {
            CFrame.new(0, -2.35, 0),
            CFrame.Angles(0, targetFlingAngle, 0) * CFrame.new(0.55, -1.15, 0.2),
            CFrame.Angles(0, -targetFlingAngle, 0) * CFrame.new(-0.55, -1.15, 0.2),
        }

        myRoot.CFrame = currentTargetRoot.CFrame * contactOffsets[targetFlingPulse]

        local lateralPush = currentTargetRoot.CFrame.RightVector * 110
        if targetFlingPulse == 3 then
            lateralPush = -lateralPush
        end

        myRoot.AssemblyLinearVelocity = lateralPush + Vector3.new(0, 95, 0)
    end)
end

