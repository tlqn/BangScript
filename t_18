    local generatedColor = Color3.fromHSV(
        Random.new():NextNumber(),
        0.72,
        1
    )

    ChatNameColorData = {
        r = math.floor(generatedColor.R * 255 + 0.5),
        g = math.floor(generatedColor.G * 255 + 0.5),
