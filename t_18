local function stopBang()
    isActive = false
    if followConnection then
        followConnection:Disconnect()
        followConnection = nil
    end
    if animTrack then
        animTrack:Stop()
        animTrack = nil
    end
    BangBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    BangBtn.Text = "Bang"
end

local function startBang(target)
    isActive = true
    BangBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
    BangBtn.Text = "Stop"

    local myChar = LocalPlayer.Character
    local hum = myChar and myChar:FindFirstChild("Humanoid")

    if hum then
        local success = pcall(function()
            local bundle = game:GetObjects("rbxassetid://5938365243")
            for _, obj in pairs(bundle) do
                if obj:IsA("Animation") then
                    animTrack = hum:LoadAnimation(obj)
                    animTrack.Looped = true
                    animTrack:Play(0.1, 1, 2)
                    return
                end
            end
        end)
        if not success then
            local anim = Instance.new("Animation")
            anim.AnimationId = "rbxassetid://5938365243"
            animTrack = hum:LoadAnimation(anim)
            animTrack.Looped = true
            animTrack:Play(0.1, 1, 2)
        end
    end

    followConnection = RunService.Heartbeat:Connect(function()
        if not isActive then return end
        local myC = LocalPlayer.Character
        local targetC = target.Character
        if myC and targetC then
            local myRoot = myC:FindFirstChild("HumanoidRootPart")
            local targetRoot = targetC:FindFirstChild("HumanoidRootPart")
            if myRoot and targetRoot then
                myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 1.5)
            end
        end
    end)
end

BangBtn.MouseButton1Click:Connect(function()
    if isActive then
        stopBang()
        return
    end
    local targetName = Input.Text
    local target = nil
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(targetName:lower()) and p ~= LocalPlayer then
            target = p
            break
        end
    end
    if target and target.Character then
        startBang(target)
    else
        warn("Player not found: " .. targetName)
    end
end)
