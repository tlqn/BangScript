local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local isActive = false
local animTrack = nil
local followConnection = nil

-- Anti-Handcuff: Auto Reset
local lastWalkSpeed = 16
local resetCooldown = false

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    if resetCooldown then return end

    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end

    if humanoid.WalkSpeed == 0 and lastWalkSpeed > 0 then
        resetCooldown = true
        task.wait(0.1)
        LocalPlayer:LoadCharacter()
        task.wait(2)
        resetCooldown = false
        return
    end

    for _, part in pairs(char:GetDescendants()) do
        if part.Name:lower():find("handcuff") or part.Name:lower():find("cuff")
        or part.Name:lower():find("arrest") then
            resetCooldown = true
            task.wait(0.1)
            LocalPlayer:LoadCharacter()
            task.wait(2)
            resetCooldown = false
            return
        end
    end

    lastWalkSpeed = humanoid.WalkSpeed
end)

