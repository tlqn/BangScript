-- ضع هذا السكربت كـ LocalScript في StarterPlayer > StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()

-- متغيرات تتحدث مع كل إحياء
local character
local humanoid
local torso
local rightShoulder
local originalC0
local renderConnection

-- دالة الإيقاف والتنظيف
local function cleanup()
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    if rightShoulder and originalC0 then
        pcall(function()
            rightShoulder.C0 = originalC0
        end)
    end
    rightShoulder = nil
    originalC0 = nil
end

-- دالة التهيئة عند ظهور الشخصية
local function onCharacterAdded(newCharacter)
    cleanup()
    character = newCharacter
    humanoid = character:WaitForChild("Humanoid")

    -- تحديد نوع الـ Rig (R6 أو R15) واختيار المفصل المناسب
    local rigType = humanoid.RigType
    local shoulderParent
    local shoulderName

    if rigType == Enum.HumanoidRigType.R6 then
        torso = character:WaitForChild("Torso")
        shoulderParent = torso
        shoulderName = "Right Shoulder"
    else
        torso = character:WaitForChild("UpperTorso")
        shoulderParent = torso
        shoulderName = "RightShoulder"
    end

    rightShoulder = shoulderParent:WaitForChild(shoulderName)
    originalC0 = rightShoulder.C0

    -- التعامل مع الموت
    humanoid.Died:Connect(cleanup)

    -- تحديث توجيه الكتف كل فريم
    renderConnection = RunService.RenderStepped:Connect(function()
        if not rightShoulder or not rightShoulder.Parent then
            cleanup()
            return
        end

        local hit = mouse.Hit
        if not hit then return end

        -- نحسب اتجاه الكتف بالنسبة للجذع
        local shoulderWorldPos = (torso.CFrame * originalC0).Position
        local lookCFrame = CFrame.new(shoulderWorldPos, hit.Position)

        -- تحويل الـ CFrame من المساحة العالمية إلى المساحة المحلية للجذع
        local relativeCFrame = torso.CFrame:ToObjectSpace(lookCFrame)

        -- تطبيق الدوران مع الحفاظ على موضع الكتف الأصلي
        rightShoulder.C0 = CFrame.new(originalC0.Position) * (relativeCFrame - relativeCFrame.Position) * CFrame.Angles(0, math.rad(90), 0)
    end)
end

-- ربط الأحداث
player.CharacterAdded:Connect(onCharacterAdded)

-- إذا الشخصية موجودة بالفعل عند تشغيل السكربت
if player.Character then
    onCharacterAdded(player.Character)
end
